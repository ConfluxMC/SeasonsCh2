options:
    defClr: <dark_purple>
    numClr: <green>
    plrClr: <aqua>
    itemClr: <aqua>
    keyClr: <gray>
    multStr: " <dark_gray>× "

on load:
    set {solstice_shard} to first element of loot of loot table "conflux_seasons:solstice_shard"

command /sols:
    aliases: /shards, /solstice-shards
    executable by: players
    trigger:
        set {_cmp} to minimessage from "{@defClr}You have "
        add solsSprite(solsBalance(player), sender, "#") to {_cmp}
        add "{@defClr} Solstice Shards." to {_cmp}
        send component {_cmp} to player
command /sols-balances [<player>]:
    aliases: /sols-report
    permission: server.admin
    trigger:
        if arg-1 is set:
            set {_cmp} to minimessage from "{@plrClr}%arg-1%{@defClr} has "
            add solsSprite(solsBalance(arg-1), sender, "#") to {_cmp}
            add minimessage from "{@defClr} Solstice Shards." to {_cmp}
            send component {_cmp} to sender
        else:
            loop offline players:
                add "%solsBalance(loop-value)%,%loop-value%" to {_solsList::*}
            set {_report} to minimessage from "{@defClr}Solstice Shard Balances"
            sort {_solsList::*} in descending order
            loop {_solsList::*}:
                set {_balPlr::*} to loop-value split by ","
                set {_p} to 2nd element of {_balPlr::*} parsed as offlineplayer
                add minimessage from "%nl%{@plrClr}%{_p}% " to {_report}
                add solsSprite(solsBalance({_p}), sender, "#") to {_report}
                
        if sender is console:
            set {_actualReport} to {_report}
            set {_report} to minimessage from "Generating Sols Balances report...%nl%"
            add {_actualReport} to {_report}
        send component {_report} to sender

function solsBalance(p: offlineplayer):: integer:
    if {_p} is online:
        set {_scoreSols} to score of {_p} for objective with id "solstice_shards"
        set {sols_shop.players.sols::%{_p}%} to {_scoreSols}
        return {_scoreSols}
    return {sols_shop.players.sols::%{_p}%}

on quit:
    set {sols_shop.players.sols::%player%} to solsBalance(player)

command /sols-give-item <integer> [<player>] [<boolean>]:
    permission: server.admin
    trigger:
        if arg-2 is set:
            giveSols(arg-1,arg-2,true,arg-3)
        else:
            giveSols(arg-1,player,true,arg-3)
command /sols-give <integer> [<player>] [<boolean>]:
    permission: server.admin
    trigger:
        set {_p} to arg-2
        if {_p} is not set:
            set {_p} to player
            
        giveSols(arg-1,{_p},false,arg-3)

command /sols-add-to-stats <integer> <offlineplayer>:
    permission: server.admin
    trigger:
        add arg-1 to {sols_shop.players.sols.earned::%arg-2%}

local function giveSols(amt: integer, p: player, asItem: boolean, playSound: boolean = true):
    if {_asItem} is true:
        give or drop {_amt} of {solstice_shard} to {_p}
    else:
        add {_amt} to score of {_p} for objective with id "solstice_shards"
    if {_playSound} is true:
        play sound "minecraft:block.amethyst_block.step" with pitch 1.4 at {_p} for {_p}

on custom click:
    if event-namespacedkey is "conflux_seasons:shop_open":
        make console execute command "execute as %player% run function conflux_seasons:shop/pre_open"
    else:
        set {_payload} to event-nbt
        if event-namespacedkey is "conflux_seasons:shop_buy":
            set {_key} to string tag "index" of {_payload}
            if {sols_shop.items.cost::%{_key}%} <= solsBalance(player):
                set {_index} to {sols_shop.items.index::%{_key}%}
                if {sols_shop.players::*} does not contain player:
                    add player to {sols_shop.players::*}
                add 1 to {sols_shop.players::%player%::%{_key}%}
                make console execute command "execute as %player% at @s run function conflux_seasons:shop/buy/check_balance with storage conflux_seasons:shop items[%{_index}%]"
                ################# BATTLEPASS PALCEHOLDER MARKER FOR DAILY PURCHASE ####################
                addPlaceholder(player, "sols_shop_purchases", 1)
            else:
                play sound "minecraft:entity.villager.no" at player for player
                send "&cYou need %solsSprite({sols_shop.items.cost::%{_key}%} - solsBalance(player),player,"#")%&c more to purchase {@itemClr}%{sols_shop.items.name::%{_key}%}%&c."
        else if event-namespacedkey is "conflux_seasons:shop_withdraw_sols":
            set {_amt} to float tag "withdraw_range" of {_payload}
            if all:
                {_amt} > 0
                {_amt} <= solsBalance(player)
            then:
                giveSols({_amt}*-1,player,false,false)
                giveSols({_amt},player,true,true)
            else:
                play sound "minecraft:entity.villager.no" at player for player
                send "&cCould not withdraw %solsSprite({_amt},player,"#")%&c." to player
        else if event-namespacedkey is "conflux_seasons:battlepass_open":
            make player execute command "bp open portal"
        else if event-namespacedkey is "conflux_seasons:sols_noise_easter_egg":
            play sound "minecraft:block.amethyst_block.step" with pitch 1.4 at player for player

command /sols-shop [<string>]:
    aliases: /shop
    trigger:
        if arg-1 is "sols_noise_easter_egg":
            play sound "minecraft:block.amethyst_block.step" with pitch 1.4 at player for player
        else:
            make console execute command "execute as %player% run function conflux_seasons:shop/pre_open"

command /sols-shop-which-commands-wipe-stats:
    permission: server.admin
    trigger:
        send "&7/sols-shop-init confirm &fCan keep stats by adding 'false' as a 2nd arg" to sender
        send "&7/sols-shop-remove <item> &fDeletes all stats related to the removed item" to sender

command /sols-shop-init [<string>] [<boolean=true>]:
    permission: server.admin
    trigger:
        if arg-1 is "confirm":
            make sender execute command "function conflux_seasons:shop/shop_defaults"
            make sender execute command "data modify storage conflux_seasons:shop items set value [{}]"
            make sender execute command "function conflux_seasons:shop/rebuild"
            
            if arg-2 is true:
                delete {sols_shop.items.index::*}
                delete {sols_shop.items.cost::*}
                delete {sols_shop.items.name::*}
                loop {sols_shop.players::*}:
                    delete {sols_shop.players::%loop-value%::*}
        else:
            send "Are you sure? Please send &7/shop-init confirm&r to confirm." to sender

