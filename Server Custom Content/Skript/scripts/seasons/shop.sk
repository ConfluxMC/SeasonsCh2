#    trigger:
#        send arg-1 to sender

local function solsSprite(amt: integer, s: sender, format: string = "00"):: text component:
    if {_s} is console:
        return minimessage from "<light_purple>%formatNumber({_amt},{_format})% Sols"
    else:
        set {_cmp} to minimessage from "<light_purple>%formatNumber({_amt},{_format})%"
        set {_spr} to object text component with atlas "minecraft:items" with sprite "conflux_seasons:item/solstice_shard"
        #add click event to run command "sols-shop sols_noise_easter_egg" to {_spr}
        set {_emptyNbt} to nbt compound from "{}"
        add click event to run custom payload with key "conflux_seasons:sols_noise_easter_egg" with data {_emptyNbt} to {_spr}
        set color format of {_spr} to white
        add {_spr} to {_cmp}
        return {_cmp}

local function itemString(key: string, s: sender):: text component:
    set {_cmp} to solsSprite({sols_shop.items.cost::%{_key}%},{_s})
    add minimessage from "{@itemClr}%{sols_shop.items.name::%{_key}%}% {@keyClr}(%{_key}%)" to {_cmp}
    return {_cmp}

command /sols-shop-records-player [<string>] [<string>]:
    trigger:
        if sender is not op:
            set {_p} to player
        else:
            if all:
                arg-1 is set
                arg-1 is not "*"
            then:
                set {_p} to arg-1 parsed as player
        set {_solsTotal} to 0
        set {_total} to 0
        if {_p} is set:
            set {_report} to minimessage from "{@defClr}Purchase History for {@plrClr}%{_p}%"
            loop {sols_shop.players::%{_p}%::*}:
                if any:
                    arg-2 is not set
                    arg-2 is loop-index
                then:
                    set {_itemCost} to {sols_shop.items.cost::%loop-index%}
                    add ({_itemCost} * loop-value) to {_solsTotal}
                    add loop-value to {_total}
                    add minimessage from "%nl%{@numClr}%formatNumber(loop-value,"00")%%{@multStr}%" to {_report}
                    add itemString(loop-index,sender) to {_report}
            if {_total} is 1:
                set {_purchaseStr} to "purchase"
            else:
                set {_purchaseStr} to "purchases"
            add minimessage from "%nl%{@defClr}Total of " to {_report}
            add solsSprite({_solsTotal},sender) to {_report}
            add minimessage from "{@defClr} spent across {@numClr}%{_total}%{@defClr} %{_purchaseStr}%." to {_report}
        else:
            set {_totalPlrs} to 0
            set {_report} to minimessage from "{@defClr}Purchase History"
            loop {sols_shop.players::*}:
                set {_p} to loop-value
                add 1 to {_totalPlrs}
                if {sols_shop.players::%{_p}%::*} is set:
                    loop {sols_shop.players::%{_p}%::*}:
                        if any:
                            arg-2 is not set
                            arg-2 is loop-index-2
                        then:
                            set {_itemName} to {sols_shop.items.name::%loop-index-2%}
                            set {_itemCost} to {sols_shop.items.cost::%loop-index-2%}
                            add ({_itemCost} * loop-value-2) to {_solsTotal}
                            add loop-value-2 to {_total}
                            add minimessage from "%nl%{@plrClr}%{_p}% {@numClr}%formatNumber(loop-value-2,"00")%%{@multStr}%" to {_report}
                            add itemString(loop-index-2,sender) to {_report}
            if {_total} is 1:
                set {_purchaseStr} to "purchase"
            else:
                set {_purchaseStr} to "purchases"
            if {_totalPlrs} is 1:
                set {_plrStr} to "player"
            else:
                set {_plrStr} to "players"
            add minimessage from "%nl%{@defClr}Total of " to {_report}
            add solsSprite({_solsTotal},sender) to {_report}
            add minimessage from "{@defClr} spent across {@numClr}%{_total}%{@defClr} %{_purchaseStr}% and {@numClr}%{_totalPlrs}%{@defClr} %{_plrStr}%." to {_report}
        if sender is console:
            set {_actualReport} to {_report}
            set {_report} to minimessage from "Generating Sols Shop report...%nl%"
            add {_actualReport} to {_report}
        send component {_report} to sender

on tab complete of "/sols-shop-records-player":
    set tab completions for position 1 to {sols_shop.players::*}
    set tab completions for position 2 to indexes of {sols_shop.items.index::*}
        
command /sols-shop-records-item [<string>]:
    permission: server.admin
    trigger:
        set {_total} to 0
        if arg-1 is set:
            set {_key} to arg-1
            set {_report} to minimessage from "{@defClr}Purchase Records for "
            add itemString({_key},sender) to {_report}
            loop {sols_shop.players::*}:
                set {_plr} to loop-value
                if {sols_shop.players::%{_plr}%::%{_key}%} is set:
                    set {_plrPurchased} to {sols_shop.players::%{_plr}%::%{_key}%}
                    add {_plrPurchased} to {_total}
                    add minimessage from "%nl%{@numClr}%formatNumber({_plrPurchased} ,"00")%%{@multStr}%{@plrClr}%{_plr}%" to {_report}
            add minimessage from "%nl%{@defClr}Total Purchased:{@numClr} %{_total}%" to {_report}
        else:
            set {_report} to minimessage from "{@defClr}Item Purchase Records"
            set {_solsTotal} to 0
            loop indexes of {sols_shop.items.index::*}:
                set {_plrPurchased} to 0
                set {_key} to loop-value
                loop {sols_shop.players::*}:
                    set {_plr} to loop-value-2
                    if {sols_shop.players::%{_plr}%::%{_key}%} is set:
                        set {_plrPurchased} to {sols_shop.players::%{_plr}%::%{_key}%}
                        add {_plrPurchased} to {_total}
                        add ({_plrPurchased} * {sols_shop.items.cost::%{_key}%}) to {_solsTotal}
                add minimessage from "%nl%{@numClr}%formatNumber({_plrPurchased} ,"000")%%{@multStr}%" to {_report}
                add itemString({_key},sender) to {_report}
            if {_total} is 1:
                set {_purchaseStr} to "purchase"
            else:
                set {_purchaseStr} to "purchases"
            if {_totalPlrs} is 1:
                set {_plrStr} to "player"
            else:
                set {_plrStr} to "players"
            set {_totalPlrs} to size of {sols_shop.players::*}
            add minimessage from "%nl%{@defClr}Total of " to {_report}
            add solsSprite({_solsTotal},sender) to {_report}
            add minimessage from "{@defClr} spent across {@numClr}%{_total}%{@defClr} %{_purchaseStr}% and {@numClr}%{_totalPlrs}%{@defClr} %{_plrStr}%." to {_report}
                
        if sender is console:
            set {_actualReport} to {_report}
            set {_report} to minimessage from "Generating Sols Shop report...%nl%"
            add {_actualReport} to {_report}
        send component {_report} to sender

on tab complete of "/sols-shop-records-item":
    set tab completions for position 1 to indexes of {sols_shop.items.index::*}