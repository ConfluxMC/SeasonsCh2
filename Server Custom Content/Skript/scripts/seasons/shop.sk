local function shopAdd(p: player, cost: integer, name: string, skKey: string, setFrom: string = "entity @s SelectedItem"):
    if {sols_shop.items.index::%{_skKey}%} is set:
        set {_size} to {sols_shop.items.index::%{_skKey}%}
        set {_updated} to true
    else:
        set {_size} to (size of {sols_shop.items.index::*}) + 1
        make {_p} execute command "data modify storage conflux_seasons:shop items append value {key:%{_skKey}%,icon:{atlas:""minecraft:items"",sprite:""conflux_seasons:item/solstice_shard""}}"
    make {_p} execute command "data modify storage conflux_seasons:shop items[%{_size}%] merge value {cost:%{_cost}%,label:{text:"" %{_name}% ""}}"
    make {_p} execute command "data modify storage conflux_seasons:shop items[%{_size}%].item set from %{_setFrom}%"
    set {sols_shop.items.index::%{_skKey}%} to {_size}
    set {sols_shop.items.cost::%{_skKey}%} to {_cost}
    set {sols_shop.items.name::%{_skKey}%} to {_name}
    
    if {_updated} is set:
        send "&aUpdated %{_skKey}% with values name: %{_name}%, cost: %{_cost}% at index %{_size}%" to {_p}
    else:
        send "&aAdded %{_skKey}% with values name: %{_name}%, cost: %{_cost}% at index %{_size}%" to {_p}

local function shopBuild():
    make console execute command "function conflux_seasons:shop/rebuild"

#                             key      Cost      Name
command /sols-shop-set-keyed <string> <integer> <text>:
    permission: server.admin
    trigger:
        shopAdd(player,arg-2,arg-3,arg-1)
        shopBuild()

on tab complete of "/sols-shop-set-keyed":
	set tab completions for position 1 to "new_key", and indexes of {sols_shop.items.index::*}
	set tab completions for position 2 to "cost"
	set tab completions for position 3 to "name"

#                            key      Atlas  Sprite
command /sols-shop-set-icon <string> <text> <text>:
    permission: server.admin
    trigger:
        if arg-1 is set:
            if arg-2 is not set:
                set {_atlas} to "minecraft:items"
            else:
                set {_atlas} to arg-2
            if arg-3 is not set:
                set {_sprite} to "conflux_seasons:item/solstice_shard"
            else:
                set {_sprite} to arg-3
            set {_index} to {sols_shop.items.index::%arg-1%}
            make player execute command "data modify storage conflux_seasons:shop items[%{_index}%].icon set value {atlas:""%{_atlas}%"",sprite:""%{_sprite}%"",shadow_color:0}"
            make player execute command "function conflux_seasons:shop/rebuild"
        else:
            send "Must specify the key!" to player

on tab complete of "/sols-shop-set-icon":
    set tab completions for position 1 to indexes of {sols_shop.items.index::*}
    set tab completions for position 2 to "atlas_name", "blocks", "items", "celestials", "decorated_pot", "gui", "map_decorations", "paintings", and "particles"
    set tab completions for position 3 to "sprite_name", "block/", "item/", "entity/decorated_pot/", and "mob_effect/"

command /sols-shop-remove <string>:
    permission: server.admin
    trigger:
        set {_key} to arg-1
        set {_index} to {sols_shop.items.index::%{_key}%}
        make player execute command "data remove storage conflux_seasons:shop items[%{_index}%]"
        shopBuild()
        delete {sols_shop.items.index::%{_key}%}
        delete {sols_shop.items.name::%{_key}%}
        delete {sols_shop.items.cost::%{_key}%}
        loop {sols_shop.players::*}:
            delete {sols_shop.players::%loop-value%::%{_key}%}
        loop {sols_shop.items.index::*}:
            if loop-value > {_index}:
                set {sols_shop.items.index::%loop-index%} to loop-value - 1 # Since the storage data will decrements its indexes, update tracking in skript too

on tab complete of "/sols-shop-remove":
    set tab completions for position 1 to indexes of {sols_shop.items.index::*}

command /sols-shop-set-from-chest <integer> <integer> <integer>:
    permission: server.admin
    executable by: players
    trigger:
        set {_chest} to inventory of block at location at arg-1, arg-2, arg-3
        if {_chest} is set:
            set {_slot} to 0
            set {_size} to {_chest}'s amount of slots
            loop {_size} times:
                set {_slot} to loop-value - 1
                set {_item} to item in slot {_slot} of {_chest}
                if {_item} is of type {solstice_shard}:
                    set {_sellItem} to item in slot {_slot} + 2 of {_chest}
                    set {_key} to custom name of item in slot {_slot} + 1 of {_chest}
                    set {_name} to custom name of {_item}
                    set {_cost} to {_item}'s amount
                    
                    set {_valid} to true
                    if {_key} is not set:
                        send "&cMissing key for %{_sellItem}%"
                        set {_valid} to false
                    if {_name} is not set:
                        send "&cMissing name for %{_sellItem}%"
                        set {_valid} to false
                    if {_cost} is not set:
                        send "&cMissing cost for %{_sellItem}%"
                        set {_valid} to false
                    if any:
                        {_sellItem} is not set
                        {_sellItem} is air
                    then:
                        send "&cMissing sell item for item at slot %{_slot}%"
                        set {_valid} to false
                    
                    #set {_argStr} to "Key: '%{_key}%' Name: '%custom name of {_item}%' Cost: '%{_item}'s amount%' Slot: %{_slot}%"
                    #send {_argStr} to player
                    
                    if {_valid} is true:
                        set {_anyAdded} to true
                        shopAdd(player,{_item}'s amount,custom name of {_item},{_key},"block %arg-1% %arg-2% %arg-3% Items[%{_slot} + 2%]")
            if {_anyAdded} is true:
                shopBuild()
        else:
            send "&cInvalid block" to player

on tab complete of "/sols-shop-set-from-chest":
    set tab completions for position 1 to floor(x coordinate of target block of player)
    set tab completions for position 2 to floor(y coordinate of target block of player)
    set tab completions for position 3 to floor(z coordinate of target block of player)

