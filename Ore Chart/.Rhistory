library(tidyverse)
library(sqldf)
library(RColorBrewer)
library(ggpubr)
library(png)
ore_distribution
#my_data$id <- c(row_number(my_data))
mydata <- sqldf("select od.id, od.ore oreId, o.ore ore, o.color cname, od.dimension, od.type,
max(min((od.count*od.size)/25.0,25),10) count,
if(od.minType='ab', d.bottom+od.min, if(od.minType='bt', d.top-od.min, od.min)) min,
if(od.maxType='ab', d.bottom+od.max, if(od.maxType='bt', d.top-od.max, od.max)) max
from ore_distribution od
inner join dimensions d on od.dimension = d.id
inner join ores o on od.ore = o.id")
mydata <- sqldf("select o.id, o.oreId, o.ore, o.cname, o.dimension, o.type, o.count, c.totalCount, min, max from mydata o
inner join (select oreId, SUM(count) totalCount from mydata group by oreId) c on o.oreId = c.oreId")
mydata
offsetData <- sqldf("
select (select SUM(asum) from ( --cteRanked
select asum, oreId, ROW_NUMBER() OVER(ORDER BY oreId) rownum from ( --cte
select oreId, SUM(count)asum from mydata group by oreId
)
) c2 where c2.rownum <= c1.rownum
) xOffset, oreId from ( --cteRanked
select asum, oreId, ROW_NUMBER() OVER(ORDER BY oreId) rownum from ( --cte
select oreId, SUM(count) asum from mydata group by oreId
)
) c1")
offsetData
mydata <- sqldf("select o.id, o.oreId, ore, cname, dimension, type, count, totalCount, xoffset, min, max from mydata o
inner join offsetData off on off.oreId = o.oreId")
mydata
mydata <- sqldf("select id, oreId, ore, cname, dimension, type, count, totalCount, xoffset,
if(type=0,0,count) x,
if(type=0,min,(min+max)/2) y
from mydata
union
select id, oreId, ore, cname, dimension, type, count, totalCount, xoffset, x, y from (
select id, oreId, ore, cname, dimension, type, count, totalCount, xoffset, x, y from (
select id, oreId, ore, cname, dimension, type, count, totalCount, xoffset, 0 x, max y from mydata a  -- top left
union
select id, oreId, ore, cname, dimension, type, count, totalCount, xoffset, if(type=0,count,0) x, max y from mydata b) -- top right
)
union
select id, oreId, ore, cname, dimension, type, count, totalCount, xoffset, x, y from (
select id, oreId, ore, cname, dimension, type, count, totalCount, xoffset, if(type=0,count,0) x, min y from mydata b -- bottom right
union
select id, oreId, ore, cname, dimension, type, count, totalCount, xoffset, 0 x, min y from mydata a) -- bottom left
order by oreId
")
i <- 1
thirdx <- -1
thirdy <- -1
#initOffset <- 0
initOffset <- mydata[1,"xOffset"]
for(c in 1:nrow(mydata))
{
mydata[c,"xOffset"] <- mydata[c,"xOffset"]-initOffset
if (mydata[c,"type"] == 0)
{
if (i == 3) {
thirdx <- mydata[c,"x"]
thirdy <- mydata[c,"y"]
}
if (i == 4) {
if (mydata[c-1,"x"] != mydata[c-2,"x"] && mydata[c-1,"y"] != mydata[c-2,"y"]){
mydata[c-1,"x"] <- mydata[c,"x"]
mydata[c-1,"y"] <- mydata[c,"y"]
mydata[c,"x"] <- thirdx
mydata[c,"y"] <- thirdy
}
i <- 1
}
else
{
i <- i + 1
}
} else {
i <- 1
}
}
mydata
