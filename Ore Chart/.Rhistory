breaks = c(-64,-32,0,32,64,96,128,160,192,224,256,288,320,352),
minor_breaks = c(-48,-16,16,48,80,112,144,176,208,240,272,304,336)) +
scale_fill_manual(values=mycolors) +
theme(panel.grid.major.y = element_line(color = 'grey',
linewidth = 1,
linetype = 1),
panel.grid.minor.y = element_line(color = 'grey',
linewidth = 0.8,
linetype = 2),
panel.background = element_rect(fill = 'darkgrey'),
panel.grid.major.x = element_line(color='darkgrey'),
panel.grid.minor.x = element_line(color='darkgrey')
)
