{
  "pack": {
    "min_format": 82,
    "max_format": 94,
    "description": "Conflux Seasons Chapter 2: Hollow Earth datapack patcher"
  },
  "filter": {
    "block": [
      {
        "namespace": "chakram",
        "path": "^advancement\\/(visible\\/((?!chakram\\.json$|target\\.json$).*)|loot\\.json$)"
      },
      {
        "namespace": "chakram",
        "path": "function/loot"
      },
      {
        "namespace": "minecraft",
        "path": "^advancement\/(nether|end|story\/(root|enter_the_nether|follow_ender_eye|enter_the_end)\\.json)"
      }
    ]
  }
}