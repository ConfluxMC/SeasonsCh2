# tag tentacle segments as selected. first start with the segment connected to the base, then the rest are identified based on it being the segment positioned 1.25 blocks above (relative to the current segment's rotation) the current segment.
tag @n[type=minecraft:block_display,tag=deeper_dark.tentacle_segment.1,scores={deeper_dark.var=0},distance=0..10] add deeper_dark.selected_all
execute at @n[type=minecraft:block_display,tag=deeper_dark.selected_all,tag=deeper_dark.tentacle_segment.1] positioned ^ ^1.25 ^ run tag @n[type=minecraft:block_display,tag=deeper_dark.tentacle_segment.2,scores={deeper_dark.var=0},distance=0..10] add deeper_dark.selected_all
