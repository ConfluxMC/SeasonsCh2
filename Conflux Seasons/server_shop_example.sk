#        if indexes of {sols_shop.items.index::*} contains 
#        set {sols_shop.items.index::%arg-1%} to {sols_shop.items.index::%arg-1%}
#        set {_index} to {sols_shop.items.index::%arg-1%}

command /shop-minimsg <string>:
    trigger:
        send arg-1 to sender

local function solsSprite(amt: integer, s: sender, format: string = "00"):: string:
    if {_s} is console:
        return "&d%formatNumber({_amt},{_format})% Sols"
    else:
        return "&d%formatNumber({_amt},{_format})%&r<click:run_command:shop sols_noise_easter_egg><sprite:""minecraft:items"":""conflux_seasons:item/solstice_shard""></click>"

local function itemString(key: string, s: sender):: string:
    return "%solsSprite({sols_shop.items.cost::%{_key}%},{_s})% {@itemClr}%{sols_shop.items.name::%{_key}%}% {@keyClr}(%{_key}%)"

command /shop-records-player [<string>] [<string>]:
    trigger:
        if sender is not op:
            set {_p} to player
        else:
            if all:
                arg-1 is set
                arg-1 is not "*"
            then:
                set {_p} to arg-1 parsed as player
        set {_solsTotal} to 0
        set {_total} to 0
        if {_p} is set:
            set {_report} to "{@defClr}Purchase History for {@plrClr}%{_p}%"
            loop {sols_shop.players::%{_p}%::*}:
                if any:
                    arg-2 is not set
                    arg-2 is loop-index
                then:
                    set {_itemCost} to {sols_shop.items.cost::%loop-index%}
                    add ({_itemCost} * loop-value) to {_solsTotal}
                    add loop-value to {_total}
                    add "%nl%{@numClr}%formatNumber(loop-value,"00")%%{@multStr}%%itemString(loop-index,sender)%" to {_report}
            if {_total} is 1:
                set {_purchaseStr} to "purchase"
            else:
                set {_purchaseStr} to "purchases"
            add "%nl%{@defClr}Total of %solsSprite({_solsTotal},sender)%{@defClr} spent across {@numClr}%{_total}%{@defClr} %{_purchaseStr}%." to {_report}
        else:
            set {_totalPlrs} to 0
            set {_report} to "{@defClr}Purchase History"
            loop {sols_shop.players::*}:
                set {_p} to loop-value
                add 1 to {_totalPlrs}
                if {sols_shop.players::%{_p}%::*} is set:
                    loop {sols_shop.players::%{_p}%::*}:
                        send "%loop-index-2% = %arg-2%" to sender
                        if any:
                            arg-2 is not set
                            arg-2 is loop-index-2
                        then:
                            set {_itemName} to {sols_shop.items.name::%loop-index-2%}
                            set {_itemCost} to {sols_shop.items.cost::%loop-index-2%}
                            add ({_itemCost} * loop-value-2) to {_solsTotal}
                            add loop-value-2 to {_total}
                            add "%nl%{@plrClr}%{_p}% {@numClr}%formatNumber(loop-value-2,"00")%%{@multStr}%%itemString(loop-index-2,sender)%" to {_report}
            if {_total} is 1:
                set {_purchaseStr} to "purchase"
            else:
                set {_purchaseStr} to "purchases"
            if {_totalPlrs} is 1:
                set {_plrStr} to "player"
            else:
                set {_plrStr} to "players"
            add "%nl%{@defClr}Total of %solsSprite({_solsTotal},sender)%{@defClr} spent across {@numClr}%{_total}%{@defClr} %{_purchaseStr}% and {@numClr}%{_totalPlrs}%{@defClr} %{_plrStr}%." to {_report}
        if sender is console:
            set {_report} to "&rGenerating Sols Shop report...%nl%%{_report}%"
        send {_report} to sender

on tab complete of "/shop-records-player":
    set tab completions for position 1 to {sols_shop.players::*}
    set tab completions for position 2 to indexes of {sols_shop.items.index::*}
        
command /shop-records-item [<string>]:
    permission: server.admin
    trigger:
        set {_total} to 0
        if arg-1 is set:
            set {_key} to arg-1
            set {_report} to "{@defClr}Purchase Records for %itemString({_key},sender)%"
            loop {sols_shop.players::*}:
                set {_plr} to loop-value
                if {sols_shop.players::%{_plr}%::%{_key}%} is set:
                    set {_plrPurchased} to {sols_shop.players::%{_plr}%::%{_key}%}
                    add {_plrPurchased} to {_total}
                    add "%nl%{@numClr}%formatNumber({_plrPurchased} ,"00")%%{@multStr}%{@plrClr}%{_plr}%" to {_report}
            add "%nl%{@defClr}Total Purchased:{@numClr} %{_total}%" to {_report}
        else:
            set {_report} to "{@defClr}Item Purchase Records"
            loop indexes of {sols_shop.items.index::*}:
                set {_key} to loop-value
                loop {sols_shop.players::*}:
                    set {_plr} to loop-value-2
                    if {sols_shop.players::%{_plr}%::%{_key}%} is set:
                        set {_plrPurchased} to {sols_shop.players::%{_plr}%::%{_key}%}
                        add {_plrPurchased} to {_total}
                add "%nl%{@numClr}%formatNumber({_total} ,"000")%%{@multStr}%%itemString({_key},sender)%" to {_report}
                
        if sender is console:
            set {_report} to "&rGenerating Sols Shop report...%nl%%{_report}%"
        send {_report} to sender

on tab complete of "/shop-records-item":
    set tab completions for position 1 to indexes of {sols_shop.items.index::*}